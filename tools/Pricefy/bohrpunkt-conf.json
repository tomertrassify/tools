{
  "_meta": {
    "description": "Preis-Konfiguration fuer den Bohrpunktrechner.",
    "version": 3
  },
  "_readme": [
    "Jede Variante entspricht einer Spalte aus der Preisliste.",
    "Reihenfolge hier: 1. Trassify Standard, 2. Nur Digitalisierung, 3. Nur Leitungsauskunft.",
    "Es gilt immer die hoechste passende Staffel: minimumPoints <= sichtbare Bohrpunkte.",
    "Die Preisberechnung erfolgt clusterweise.",
    "Der Clustermodus kann testweise von Distanz auf Gemeinde umgestellt werden.",
    "Gemeinden werden dabei direkt aus OSM ueber administrative Grenzen gelesen.",
    "Fuer Geschwindigkeit werden keine Gemeindeflaechen angezeigt, sondern nur Punkt-zu-Gemeinde-Zuordnungen berechnet."
  ],
  "bohrpunktCalculator": {
    "_comment": "Die Preise aus dem Screenshot wurden auf die fachlichen Varianten umgelegt: Spalte 1 = Nur Leitungsauskunft, Spalte 2 = Nur Digitalisierung, Spalte 3 = Trassify Standard.",
    "clustering": {
      "mode": "municipality",
      "distanceMeters": 1000,
      "municipalityResolver": {
        "_comment": "Gemeinden werden ueber OSM-/Overpass-Grenzen mit admin_level 8 und Fallback 7 aufgeloest. Die Abfragen laufen parallel pro Punktgruppe, nicht ueber Gemeindeflaechen.",
        "adminLevels": [8, 7],
        "maxConcurrentRequests": 6,
        "requestTimeoutMs": 12000,
        "requestDelayMs": 0
      }
    },
