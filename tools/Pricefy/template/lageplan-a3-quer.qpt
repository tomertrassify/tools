   <Option type="bool" value="false" name="rasterize"/>
   <Option type="double" value="5" name="resizeToContentsBottomMargin"/>
   <Option type="double" value="5" name="resizeToContentsLeftMargin"/>
   <Option type="double" value="10" name="resizeToContentsRightMargin"/>
   <Option type="double" value="5" name="resizeToContentsTopMargin"/>
   <Option type="bool" value="true" name="singleFile"/>
  </Option>
 </customproperties>
 <Atlas hideCoverage="0" filterFeatures="0" sortFeatures="0" enabled="1" coverageLayer="" filenamePattern="'output_'||@atlas_featurenumber" pageNameExpression="&quot;id&quot;"/>
</Layout>
